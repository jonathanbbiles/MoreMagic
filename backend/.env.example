# MoreMagic backend — local/dev example. Copy to backend/.env and fill in.
# NEVER commit a real .env (the pre-commit hook blocks it).

# --- Mode (paper-first) ---
TRADING_MODE=paper
ASSET_CLASS=equities            # equities | crypto

# --- Alpaca (PAPER) credentials ---
APCA_API_KEY_ID=your_paper_key_id
APCA_API_SECRET_KEY=your_paper_secret_key
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# --- Strategy knobs (override any liveDefaults key here) ---
EQUITIES_UNIVERSE=SPY,QQQ,AAPL,MSFT,NVDA,AMD,TSLA,META,AMZN,GOOGL
ACTIVE_SIGNALS=momentum
POSITION_SIZING_PCT=0.10
MAX_OPEN_POSITIONS=4
TAKE_PROFIT_BPS=120
STOP_LOSS_BPS=80
MAX_HOLD_MINUTES=180
SCAN_INTERVAL_SEC=30
ENABLE_TRADING=true

# --- Trading costs (fees + spread + slippage; net the backtest & the breaker) ---
# Equities are commission-free on Alpaca; crypto charges a taker fee (~0.25%).
# Market orders are always the taker. These feed modules/costs/costModel.js.
TAKER_FEE_BPS_EQUITIES=0
TAKER_FEE_BPS_CRYPTO=25
REG_FEE_BPS_SELL=0.5
ASSUMED_SLIPPAGE_BPS=2
ASSUMED_SPREAD_BPS=3
# Live promotion requires this be true (validate NET-of-cost expectancy first):
REQUIRE_BACKTEST_VALIDATION=false

# --- Optional dashboard auth (leave blank to disable) ---
API_TOKEN=
DASHBOARD_ORIGINS=http://localhost:19006,http://localhost:8081
PORT=3000
