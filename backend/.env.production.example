# MoreMagic backend — production template (set these in Render's dashboard).
# Going LIVE is a deliberate, separate step: TRADING_MODE=live + ALLOW_LIVE=true
# + the LIVE base URL + live keys, and only after the paper scorecard validates.

TRADING_MODE=paper
ASSET_CLASS=equities
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ENABLE_TRADING=true
API_TOKEN=set_a_long_random_token
DASHBOARD_ORIGINS=https://your-dashboard-origin
PORT=3000

# Trading costs — feed the cost model so the backtest gate and the live circuit
# breaker net trades identically (fees + spread + slippage). Crypto's taker fee
# (~0.25% = 25 bps/side) is the big one; equities are commission-free.
TAKER_FEE_BPS_EQUITIES=0
TAKER_FEE_BPS_CRYPTO=25
REG_FEE_BPS_SELL=0.5
ASSUMED_SLIPPAGE_BPS=2
ASSUMED_SPREAD_BPS=3

# To promote to live (do NOT do this until validated on paper):
# TRADING_MODE=live
# ALLOW_LIVE=true
# ALPACA_TRADING_BASE_URL=https://api.alpaca.markets
# APCA_API_KEY_ID=your_live_key
# APCA_API_SECRET_KEY=your_live_secret
# REQUIRE_BACKTEST_VALIDATION=true   # validateEnv REQUIRES this in live mode
